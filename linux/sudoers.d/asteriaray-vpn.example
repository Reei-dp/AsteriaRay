# Passwordless only for bundled helpers next to the binary (narrow rules).
# The app can install this automatically on first launch (one pkexec).
#
# 1) Replace YOUR_USERNAME with your login (`whoami`).
# 2) Replace paths with the REAL paths next to asteriaray/xray/awg-quick, e.g.:
#      /home/you/app/asteriaray-vpn-routes.sh
#      /home/you/app/awg-quick
# 3) Install:
#      sudo install -m 0440 asteriaray-vpn.example /etc/sudoers.d/asteriaray-vpn
#      sudo visudo -cf /etc/sudoers.d/asteriaray-vpn
#
# SETENV allows `sudo -E` so awg-quick keeps PATH + WG_QUICK_USERSPACE_IMPLEMENTATION.

Defaults!/opt/asteriaray/asteriaray-vpn-routes.sh !requiretty
Defaults!/opt/asteriaray/awg-quick !requiretty

YOUR_USERNAME ALL=(root) NOPASSWD:SETENV: /opt/asteriaray/asteriaray-vpn-routes.sh
YOUR_USERNAME ALL=(root) NOPASSWD:SETENV: /opt/asteriaray/awg-quick
